# Copy this file to ".env" and fill in your values, then restart the server.
#
# Google login is OPTIONAL. If you leave GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
# empty, the app still works fully in guest mode (progress saved in the browser);
# the "Sign in with Google" button just won't appear.
#
# To get credentials:
#   1. https://console.cloud.google.com/apis/credentials
#   2. Create credentials -> OAuth client ID -> Web application
#   3. Add Authorized redirect URI:  http://localhost:8000/auth/callback
#   4. Copy the Client ID and Client Secret below.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match exactly what you registered in Google Cloud Console.
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# Secret used to sign the session cookie. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# If left empty, a random one is generated at startup (sessions reset on restart).
SESSION_SECRET=4d1fc28372e6bccbabaf17f48e72379b4859025f221ffe8aecab0dcf477a266e

# --- Admin ---
# Comma-separated emails allowed to add/delete words (must be signed-in users).
# Everyone else can study and trigger AI sentence generation, but not edit the deck.
ADMIN_EMAILS=millad90s@gmail.com

# --- AI sentence generation (OPTIONAL) ---
# Used to generate career-specific example sentences when a word has none for a
# user's career. Without a key, the app falls back to existing sentences and the
# generation feature is disabled (no errors).
#
# Pick the provider with AI_PROVIDER: "claude" (Anthropic) or "gemini" (Google).
AI_PROVIDER=claude

# Claude (Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Gemini (Google) — cheaper/faster. Get a key at https://aistudio.google.com/apikey
# GEMINI_MODEL: gemini-2.5-flash (default) or gemini-2.5-flash-lite (cheapest).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Tokens (credits) ---
# Each new account starts with START_TOKENS. Generating AI sentences for one word
# costs TOKEN_COST_GENERATE tokens (cached results are free; guests are unmetered).
START_TOKENS=5
TOKEN_COST_GENERATE=1

# --- PayPal (OPTIONAL) — lets users buy token packages (defined in /dashboard) ---
# Create a REST app at https://developer.paypal.com/dashboard/applications.
# Without these, the "Buy tokens" button is hidden and admins top up manually.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
